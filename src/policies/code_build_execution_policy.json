{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCodeBuildTrigger",
      "Effect": "Allow",
      "Action": [
        "codebuild:StartBuild",
        "codebuild:BatchGetBuilds",
        "codebuild:StopBuild"
      ],
      "Resource": "${CODEBUILD_PROJECT_ARN}"
    },
    {
      "Sid": "AllowLambdaDeploy",
      "Effect": "Allow",
      "Action": [
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration",
        "lambda:GetFunction"
      ],
      "Resource": "${LAMBDA_FUNCTION_ARN}"
    },
    {
      "Sid": "AllowPassRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "${LAMBDA_EXECUTION_ROLE_ARN}",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "lambda.amazonaws.com"
        }
      }
    }
  ]
}